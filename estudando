#include <stdio.h>

int main() {
    int idade = 32;
    float altura = 1.70;
    char opcao = 'C';
    char nome[20] = "Morandi";

    printf("A idade do %s é: %d\n", nome, idade);
    printf("A altura é: %f\n", altura);
    printf("A opção é: %c\n", opcao);

    return 0;
}

